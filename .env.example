# Nodeticket Configuration
# Copy to .env and fill in real values:  cp .env.example .env

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ────────────────────────────────────────────────────────────────
# Dialect: mysql | postgres
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=original
DB_USER=root
DB_PASSWORD=
TABLE_PREFIX=ost_

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Session ─────────────────────────────────────────────────────────────────
# Use a long random string in any non-local environment
SESSION_SECRET=change-this-to-a-random-string
# Absolute session lifetime (ms); default 24h
SESSION_MAX_AGE=86400000
# Idle timeout (ms); default 30 minutes
SESSION_IDLE_TIMEOUT=1800000

# ── JWT (API auth) ──────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRES_IN=24h

# ── API ─────────────────────────────────────────────────────────────────────
# Max requests per 15-minute rate-limit window
API_RATE_LIMIT=100

# ── Helpdesk (optional; can also be set in DB config) ───────────────────────
HELPDESK_TITLE=Nodeticket Help Desk
HELPDESK_URL=http://localhost:3000

# ── MCP (Model Context Protocol) ────────────────────────────────────────────
MCP_ENABLED=false
MCP_JWT_SECRET=change-this-to-a-random-string
MCP_JWT_EXPIRES_IN=8h

# ── Email (AWS SES) ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=noreply@yourdomain.com
